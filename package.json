{
  "name": "prettier-eslint",
  "version": "17.0.0",
  "type": "commonjs",
  "description": "Formats your JavaScript using prettier followed by eslint --fix",
  "repository": "git+https://github.com/prettier/prettier-eslint.git",
  "homepage": "https://github.com/prettier/prettier-eslint#readme",
  "author": "Kent C. Dodds <kent@doddsfamily.us> (http://kentcdodds.com/)",
  "maintainers": [
    "Simon Fridlund <simon@fridlund.email>",
    "JounQin <admin@1stg.me> (https://www.1stG.me)"
  ],
  "funding": "https://opencollective.com/prettier-eslint",
  "license": "MIT",
  "packageManager": "yarn@4.16.0",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js",
    "lib",
    "!lib/*.tsbuildinfo"
  ],
  "keywords": [
    "eslint",
    "formatter",
    "linter",
    "prettier",
    "prettier-eslint"
  ],
  "scripts": {
    "build": "nps build",
    "format": "nps format",
    "lint": "nps lint",
    "prepare": "patch-package && simple-git-hooks && yarn-berry-deduplicate || exit 0",
    "start": "nps",
    "test": "nps test"
  },
  "peerDependencies": {
    "prettier-plugin-svelte": "^4.0.0",
    "svelte-eslint-parser": "*"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-svelte": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@esm2cjs/indent-string": "^5.0.0",
    "@typescript-eslint/parser": "^8.61.0",
    "common-tags": "^1.8.2",
    "dlv": "^1.1.3",
    "eslint": "^10.5.0",
    "lodash.merge": "^4.6.2",
    "loglevel-colored-level-prefix": "^1.0.0",
    "prettier": "^3.8.4",
    "pretty-format": "^30.4.1",
    "require-relative": "^0.8.7",
    "tslib": "^2.8.1",
    "vue-eslint-parser": "^10.4.1"
  },
  "devDependencies": {
    "@1stg/eslint-config": "^10.3.1",
    "@1stg/prettier-config": "^5.4.0",
    "@1stg/tsconfig": "^4.0.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@swc-node/jest": "^1.9.1",
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.23",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/common-tags": "^1.8.4",
    "@types/dlv": "^1.1.5",
    "@types/jest": "^30.0.0",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.9.3",
    "@types/require-relative": "^0.8.2",
    "@unts/patch-package": "^8.1.1",
    "all-contributors-cli": "^6.26.1",
    "clean-pkg-json": "^2.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-node-dependencies": "^2.2.0",
    "jest": "^30.4.2",
    "nps": "^5.10.0",
    "nps-utils": "^1.7.0",
    "prettier-eslint": "portal:.",
    "prettier-eslint-cli": "^8.0.1",
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-jsdoc-type": "^0.2.0",
    "prettier-plugin-svelte": "^4.1.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.56.3",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^6.0.3",
    "yarn-berry-deduplicate": "^6.1.3"
  },
  "resolutions": {
    "@prettier/eslint": "portal:.",
    "eslint": "^10.5.0"
  }
}
